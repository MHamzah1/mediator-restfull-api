# ============================================
# Mediator RESTful API - Environment Variables
# ============================================
# Copy file ini menjadi .env dan sesuaikan nilai-nilainya

# ============================================
# Application Settings
# ============================================
NODE_ENV=development
PORT=3000
ENABLE_SWAGGER=true

# ============================================
# Database Configuration (Neon.tech PostgreSQL)
# ============================================
# Recommended for most uses (dengan connection pooling)
DATABASE_URL=postgresql://your_user:your_password@your-host.neon.tech/your_db?sslmode=require

# For uses requiring a connection without pgbouncer
DATABASE_URL_UNPOOLED=postgresql://your_user:your_password@your-host.neon.tech/your_db?sslmode=require

# Individual parameters (optional, untuk referensi)
PGHOST=your-host.neon.tech
PGUSER=your_user
PGDATABASE=your_db
PGPASSWORD=your_password

# ============================================
# JWT Configuration
# ============================================
# PENTING: Ganti dengan secret key yang kuat untuk production!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE_IN=1d

# ============================================
# Local Development Database (Optional)
# Gunakan ini jika ingin pakai PostgreSQL lokal dengan Docker
# ============================================
# DATABASE_URL=postgresql://mediator:mediator123@postgres:5432/mediator_db
# POSTGRES_USER=mediator
# POSTGRES_PASSWORD=mediator123
# POSTGRES_DB=mediator_db

# ============================================
# Tailscale Configuration (Optional)
# Untuk akses API via Tailscale network
# ============================================
# Generate auth key di: https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# AWS S3 Configuration (Required for Vercel deployment)
# Untuk upload dan storage gambar
# ============================================
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=mediator-uploads
