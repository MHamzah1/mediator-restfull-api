# ============================================
# Development Dockerfile
# Fitur: Hot reload dengan npm run start:dev
# ============================================
FROM node:20-alpine

WORKDIR /app

# Install dependencies untuk node-gyp (bcrypt memerlukan ini)
RUN apk add --no-cache python3 make g++

# Copy package files
COPY package*.json ./

# Install all dependencies
RUN npm ci

# Copy source code
COPY . .

# Expose port
EXPOSE 3000

# Default command (akan di-override di docker-compose.dev.yml)
CMD ["npm", "run", "start:dev"]
